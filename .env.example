# Firebase (client-side — prefix with VITE_ so Vite exposes them to the browser)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Cloudinary (client-side display only)
VITE_CLOUDINARY_CLOUD_NAME=

# Cloudinary (server-side — Vercel functions only, never exposed to browser)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Inner circle JWT signing secret (32+ random bytes, server-side only)
INNER_CIRCLE_SESSION_SECRET=

# Firebase Admin SDK (server-side — Vercel functions only)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
