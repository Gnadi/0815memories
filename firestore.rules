rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Settings - only admin can write, anyone authenticated can read the hash
    match /settings/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Memories - anyone can read, only admin can write
    match /memories/{memoryId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Moments - anyone can read, only admin can write
    match /moments/{momentId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Albums - anyone can read, only admin can write
    match /albums/{albumId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
