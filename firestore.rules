rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Families — anyone can read (needed for viewer password check),
    // only the family admin can write, anyone authenticated can create
    match /families/{familyId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.adminUid == request.auth.uid;
      allow update: if request.auth != null
                    && resource.data.adminUid == request.auth.uid;
      allow delete: if false;
    }

    // Memories — anyone can read (viewers are unauthenticated),
    // only the admin of the memory's family can write
    match /memories/{memoryId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.familyId != null
                    && exists(/databases/$(database)/documents/families/$(request.resource.data.familyId))
                    && get(/databases/$(database)/documents/families/$(request.resource.data.familyId)).data.adminUid == request.auth.uid;
      allow update, delete: if request.auth != null
                    && resource.data.familyId != null
                    && get(/databases/$(database)/documents/families/$(resource.data.familyId)).data.adminUid == request.auth.uid;
    }

    // Moments — same rules as memories
    match /moments/{momentId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.familyId != null
                    && exists(/databases/$(database)/documents/families/$(request.resource.data.familyId))
                    && get(/databases/$(database)/documents/families/$(request.resource.data.familyId)).data.adminUid == request.auth.uid;
      allow update, delete: if request.auth != null
                    && resource.data.familyId != null
                    && get(/databases/$(database)/documents/families/$(resource.data.familyId)).data.adminUid == request.auth.uid;
    }

    // Albums — same rules as memories
    match /albums/{albumId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.familyId != null
                    && exists(/databases/$(database)/documents/families/$(request.resource.data.familyId))
                    && get(/databases/$(database)/documents/families/$(request.resource.data.familyId)).data.adminUid == request.auth.uid;
      allow update, delete: if request.auth != null
                    && resource.data.familyId != null
                    && get(/databases/$(database)/documents/families/$(resource.data.familyId)).data.adminUid == request.auth.uid;
    }

    // Children — admin only (not visible to viewers)
    match /children/{childId} {
      allow read: if request.auth != null
                    && resource.data.familyId != null
                    && get(/databases/$(database)/documents/families/$(resource.data.familyId)).data.adminUid == request.auth.uid;
      allow create: if request.auth != null
                    && request.resource.data.familyId != null
                    && exists(/databases/$(database)/documents/families/$(request.resource.data.familyId))
                    && get(/databases/$(database)/documents/families/$(request.resource.data.familyId)).data.adminUid == request.auth.uid;
      allow update, delete: if request.auth != null
                    && resource.data.familyId != null
                    && get(/databases/$(database)/documents/families/$(resource.data.familyId)).data.adminUid == request.auth.uid;
    }

    // Journals — admin only (private letters to children)
    match /journals/{journalId} {
      allow read: if request.auth != null
                    && resource.data.familyId != null
                    && get(/databases/$(database)/documents/families/$(resource.data.familyId)).data.adminUid == request.auth.uid;
      allow create: if request.auth != null
                    && request.resource.data.familyId != null
                    && exists(/databases/$(database)/documents/families/$(request.resource.data.familyId))
                    && get(/databases/$(database)/documents/families/$(request.resource.data.familyId)).data.adminUid == request.auth.uid;
      allow update, delete: if request.auth != null
                    && resource.data.familyId != null
                    && get(/databases/$(database)/documents/families/$(resource.data.familyId)).data.adminUid == request.auth.uid;
    }

    // Black Box — admin only (time-release sealed messages)
    match /blackbox/{boxId} {
      allow read: if request.auth != null
                    && resource.data.familyId != null
                    && get(/databases/$(database)/documents/families/$(resource.data.familyId)).data.adminUid == request.auth.uid;
      allow create: if request.auth != null
                    && request.resource.data.familyId != null
                    && exists(/databases/$(database)/documents/families/$(request.resource.data.familyId))
                    && get(/databases/$(database)/documents/families/$(request.resource.data.familyId)).data.adminUid == request.auth.uid;
      allow update, delete: if request.auth != null
                    && resource.data.familyId != null
                    && get(/databases/$(database)/documents/families/$(resource.data.familyId)).data.adminUid == request.auth.uid;
    }

    // Scrapbooks — admin only (digital scrapbook pages)
    match /scrapbooks/{scrapbookId} {
      allow read: if request.auth != null
                    && resource.data.familyId != null
                    && get(/databases/$(database)/documents/families/$(resource.data.familyId)).data.adminUid == request.auth.uid;
      allow create: if request.auth != null
                    && request.resource.data.familyId != null
                    && exists(/databases/$(database)/documents/families/$(request.resource.data.familyId))
                    && get(/databases/$(database)/documents/families/$(request.resource.data.familyId)).data.adminUid == request.auth.uid;
      allow update, delete: if request.auth != null
                    && resource.data.familyId != null
                    && get(/databases/$(database)/documents/families/$(resource.data.familyId)).data.adminUid == request.auth.uid;
    }

    // Recipes — admin only (version-controlled family recipes)
    match /recipes/{recipeId} {
      allow read: if request.auth != null
                    && resource.data.familyId != null
                    && get(/databases/$(database)/documents/families/$(resource.data.familyId)).data.adminUid == request.auth.uid;
      allow create: if request.auth != null
                    && request.resource.data.familyId != null
                    && exists(/databases/$(database)/documents/families/$(request.resource.data.familyId))
                    && get(/databases/$(database)/documents/families/$(request.resource.data.familyId)).data.adminUid == request.auth.uid;
      allow update: if request.auth != null
                    && resource.data.familyId != null
                    && request.resource.data.familyId == resource.data.familyId
                    && get(/databases/$(database)/documents/families/$(resource.data.familyId)).data.adminUid == request.auth.uid;
      allow delete: if request.auth != null
                    && resource.data.familyId != null
                    && get(/databases/$(database)/documents/families/$(resource.data.familyId)).data.adminUid == request.auth.uid;
    }

    // FCM push tokens — any client (admin or viewer) can write their own token.
    // Viewers are not Firebase-authenticated, so we allow unauthenticated writes,
    // but we still require a well-formed shape so the collection can't be abused
    // as anonymous scratch storage. Tokens are only read server-side via Firebase
    // Admin SDK (bypasses these rules).
    match /fcmTokens/{tokenId} {
      allow create, update: if request.resource.data.familyId is string
                            && request.resource.data.familyId.size() > 0
                            && request.resource.data.familyId.size() < 128
                            && request.resource.data.token is string
                            && request.resource.data.token.size() > 0
                            && request.resource.data.token.size() < 4096;
      allow delete: if false;
      allow read: if false;
    }

    // Notification queue — admin writes a doc here to trigger the Cloud Function.
    // The Cloud Function deletes the doc after processing (Admin SDK bypasses rules).
    match /notificationsQueue/{docId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }
  }
}
